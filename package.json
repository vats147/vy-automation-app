{
  "name": "vy-automation-app",
  "version": "1.0.0",
  "description": "A comprehensive task automation and workflow recording tool built with Electron.js",
  "main": "src/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run start\" \"npm run watch\"",
    "watch": "nodemon --exec electron . --watch src/",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest",
    "lint": "eslint src/",
    "setup:mcp": "./setup-mcp-servers.sh",
    "start:mcp": "./start-mcp-servers.sh",
    "test:performance": "node performance-test.js",
    "test:mcp": "npm run setup:mcp && npm run start:mcp &",
    "dev:mcp": "npm run test:mcp && npm run dev",
    "claude": "node claude-agent.js",
    "claude:demo": "echo 'demo' | node claude-agent.js",
    "claude:setup": "npm run setup:mcp && npm run claude",
    "automation": "npm run claude"
  },
  "keywords": [
    "electron",
    "automation",
    "workflow",
    "task-recording",
    "scheduling",
    "cross-platform"
  ],
  "author": "Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.0",
    "css-loader": "^6.8.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sindresorhus/is": "^7.0.2",
    "active-win": "^8.2.1",
    "applescript": "^1.0.0",
    "axios": "^1.11.0",
    "date-fns": "^2.30.0",
    "electron-store": "^8.1.0",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.3",
    "node-cron": "^3.0.2",
    "node-record-lpcm16": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "screenshot-desktop": "^1.15.0",
    "styled-components": "^6.1.0",
    "uuid": "^9.0.1",
    "ws": "^8.18.3"
  },
  "build": {
    "appId": "com.vyautomation.app",
    "productName": "Vy Automation",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": "AppImage"
    }
  }
}
